{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Command Frontmatter",
  "description": "Schema for .claude/commands/*.md YAML frontmatter",
  "type": "object",
  "required": ["description", "category", "mutates", "consumes", "produces", "result_states"],
  "properties": {
    "description": {
      "type": "string",
      "description": "What this command does"
    },
    "category": {
      "type": "string",
      "enum": ["audit", "plan", "execute", "verify", "analyze", "improve"],
      "description": "Command category"
    },
    "mutates": {
      "type": "boolean",
      "description": "Whether this command modifies files"
    },
    "consumes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Input artifact types"
    },
    "produces": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Output artifact types"
    },
    "result_states": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Possible business outcome states (not just success/fail)"
    },
    "next_on_result": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      },
      "description": "Maps each result_state to suggested follow-up commands"
    }
  },
  "additionalProperties": true
}
