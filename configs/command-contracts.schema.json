{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Command Frontmatter",
  "description": "Schema for .claude/commands/*.md YAML frontmatter",
  "type": "object",
  "required": ["description", "category", "mutates", "consumes", "produces"],
  "properties": {
    "description": {
      "type": "string",
      "description": "What this command does"
    },
    "category": {
      "type": "string",
      "enum": ["audit", "plan", "execute", "verify", "analyze", "improve"],
      "description": "Command category"
    },
    "mutates": {
      "type": "boolean",
      "description": "Whether this command modifies files"
    },
    "consumes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Input artifact types"
    },
    "produces": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Output artifact types"
    },
    "next_on_success": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Suggested commands after successful completion"
    },
    "next_on_fail": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Suggested commands when issues are found"
    }
  },
  "additionalProperties": true
}
