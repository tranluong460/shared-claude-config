{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Workflow Definition",
  "description": "Schema for .claude/workflows/*.yaml definitions",
  "type": "object",
  "required": ["name", "description", "trigger", "steps"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Machine-readable workflow identifier"
    },
    "description": {
      "type": "string",
      "description": "Human-readable workflow description"
    },
    "trigger": {
      "type": "string",
      "description": "When this workflow should be used"
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/step"
      },
      "minItems": 1,
      "description": "Ordered list of workflow steps"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "step": {
      "type": "object",
      "required": ["command", "purpose"],
      "properties": {
        "command": {
          "type": "string",
          "pattern": "^/[a-z][a-z0-9-]*$",
          "description": "Command to execute (must match a file in commands/)"
        },
        "purpose": {
          "type": "string",
          "description": "Why this step exists in the workflow"
        },
        "optional": {
          "type": "boolean",
          "default": false,
          "description": "Whether this step can be skipped"
        },
        "on_result": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              {
                "type": "string",
                "enum": ["proceed", "done", "retry", "escalate"]
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/step_ref"
                }
              }
            ]
          },
          "description": "Result-to-action mapping based on business outcome"
        }
      },
      "additionalProperties": false
    },
    "step_ref": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "command": {
          "type": "string",
          "pattern": "^/[a-z][a-z0-9-]*$"
        },
        "purpose": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
