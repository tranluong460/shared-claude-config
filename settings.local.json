{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/.env*)",
      "Edit(.env*)",
      "Edit(**/.env*)",
      "Write(.env*)",
      "Write(**/.env*)",

      "Read(**/*credentials*)",
      "Read(**/*secret*)",

      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.crt)",
      "Write(**/*.key)",
      "Write(**/*.pem)",
      "Write(**/*.crt)",

      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Write(**/id_rsa*)",
      "Write(**/id_ed25519*)",

      "Read(~/.ssh/*)",
      "Edit(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Edit(~/.aws/*)",
      "Edit(~/.gitconfig)",

      "Read(~/.gnupg/**)",
      "Edit(~/.gnupg/**)",
      "Read(~/.kube/**)",
      "Edit(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.git-credentials)",
      "Read(~/.config/gh/**)",
      "Read(~/.docker/config.json)",
      "Edit(~/.docker/config.json)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.bash_profile)",
      "Edit(~/.profile)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/suggest-commands.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/log-command.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous-commands.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-format.sh\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo \"CONTEXT RESTORED AFTER COMPACTION:\"; echo \"\"; echo \"CRITICAL RULES (always follow):\"; echo \"- Naming: E prefix (enums), I prefix (interfaces/types), verb-first functions\"; echo \"- No any type. Return types required. Max 50 lines per function.\"; echo \"- IPC changes = update ALL layers: types > handler > preload > API > hook\"; echo \"- Verify: npm run flint > npm run typecheck\"; echo \"- Package: yarn install/add, npm run scripts\"; echo \"\"; echo \"ACTIVE TASKS: Check conversation history for pending work.\"; echo \"RULES: .claude/rules/ | SKILLS: .claude/skills/ | COMMANDS: /help\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if command -v powershell.exe &>/dev/null; then powershell.exe -Command \"[System.Media.SystemSounds]::Asterisk.Play()\" 2>/dev/null; elif command -v osascript &>/dev/null; then osascript -e \"display notification \\\"Claude Code finished\\\" with title \\\"Claude Code\\\"\" 2>/dev/null; elif command -v notify-send &>/dev/null; then notify-send \"Claude Code\" \"Session finished\" 2>/dev/null; fi'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
